prefix=/usr
libdir=${prefix}/lib/x86_64-linux-gnu
includedir=${prefix}/include

Name: xkbcommon-x11
Description: XKB API common to servers and clients - X11 support
Version: 1.4.0
Requires: xkbcommon
Requires.private: xcb >= 1.10, xcb-xkb >= 1.10
Libs: -L${libdir} -lxkbcommon-x11
Cflags: -I${includedir}
